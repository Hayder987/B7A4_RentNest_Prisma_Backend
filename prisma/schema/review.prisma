model Review {
  id String @id @default(uuid())

  rating Int

  comment String

  tenantId String

  propertyId String

  createdAt DateTime @default(now())

  tenant User @relation(fields: [tenantId],references: [id])

  property Property @relation(fields: [propertyId], references: [id],onDelete: Cascade)

  @@map("reviews")
}